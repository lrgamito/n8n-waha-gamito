# Copy to production/.env.prod and replace all placeholders.

# Public domain and email
N8N_DOMAIN=n8n.gamito.qzz.io
LETSENCRYPT_EMAIL=your-email@example.com

# Pinned images
N8N_IMAGE=n8nio/n8n:latest
WAHA_IMAGE=devlikeapro/waha:gows-arm-2026.4.2
POSTGRES_IMAGE=postgres:16
REDIS_IMAGE=redis:7.4-alpine
NGINX_IMAGE=nginx:1.27-alpine
CERTBOT_IMAGE=certbot/certbot:latest

# Common
GENERIC_TIMEZONE=America/Sao_Paulo
N8N_LOG_LEVEL=info
WAHA_LOG_LEVEL=info

# n8n security
N8N_ENCRYPTION_KEY=replace-with-a-32-plus-char-random-secret
N8N_BASIC_AUTH_USER=replace-me
N8N_BASIC_AUTH_PASSWORD=replace-with-a-strong-password

# WAHA security
WAHA_API_KEY=replace-with-a-long-random-api-key
WAHA_DASHBOARD_USERNAME=replace-me
WAHA_DASHBOARD_PASSWORD=replace-with-a-strong-password
WHATSAPP_SWAGGER_USERNAME=replace-me
WHATSAPP_SWAGGER_PASSWORD=replace-with-a-strong-password

# WAHA behavior
WHATSAPP_DEFAULT_ENGINE=GOWS
WHATSAPP_HOOK_EVENTS=message

# PostgreSQL
POSTGRES_USER=n8n
POSTGRES_PASSWORD=replace-with-a-strong-db-password
POSTGRES_DB=n8n

# Redis
REDIS_PASSWORD=replace-with-a-strong-redis-password

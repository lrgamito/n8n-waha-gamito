# Copy to test/.env.test for local testing.

# Basic local credentials (do not use in production)
REDIS_PASSWORD=default
POSTGRES_USER=default
POSTGRES_PASSWORD=default
POSTGRES_DB=default

# n8n local settings
WEBHOOK_URL=http://host.docker.internal:5678
N8N_HOST=host.docker.internal
GENERIC_TIMEZONE=America/Sao_Paulo
N8N_LOG_LEVEL=debug

# WAHA local settings
WHATSAPP_HOOK_URL=http://host.docker.internal:5678/webhook/webhook
WHATSAPP_DEFAULT_ENGINE=GOWS
WHATSAPP_HOOK_EVENTS=message

# Optional WAHA security values
WAHA_API_KEY=replace-local-key
WAHA_DASHBOARD_USERNAME=admin
WAHA_DASHBOARD_PASSWORD=replace-local-password
WHATSAPP_SWAGGER_USERNAME=admin
WHATSAPP_SWAGGER_PASSWORD=replace-local-password
